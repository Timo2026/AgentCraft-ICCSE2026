# AgentCraft LLM 配置
# 复制为 .env 并修改

# ── 本地模型 (LM Studio) ──
# 注意：LM Studio 如果开启了认证，需要创建 Token
# 路径：Developer → Server Settings → Manage Tokens → Create Token
AGENTCRAFT_LLM_BASE_URL=http://127.0.0.1:1234/v1
AGENTCRAFT_LLM_API_KEY=你的LM-Studio-Token
AGENTCRAFT_LLM_MODEL=google/gemma-4-26b-a4b-qat

# ── Ollama (无需 Token) ──
# AGENTCRAFT_LLM_BASE_URL=http://localhost:11434/v1
# AGENTCRAFT_LLM_API_KEY=ollama
# AGENTCRAFT_LLM_MODEL=qwen2.5:1.5b

# ── OpenAI 云端 ──
# AGENTCRAFT_LLM_BASE_URL=https://api.openai.com/v1
# AGENTCRAFT_LLM_API_KEY=sk-your-key-here
# AGENTCRAFT_LLM_MODEL=gpt-3.5-turbo

# 如果留空或不创建 .env，AgentCraft 自动使用规则引擎（零成本、无需模型）
# 规则引擎模式下：意图分类用关键词匹配，step 代码用预设模板
# LLM 模式下：意图分类用 LLM 理解，step 代码由 LLM 动态生成
